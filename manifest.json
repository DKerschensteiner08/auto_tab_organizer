{
  "manifest_version": 3,
  "name": "Smart Tab Tidy (OpenAI AI)",
  "description": "Group tabs by domain and OpenAI semantic similarity, park sessions, restore tabs, and close duplicates.",
  "version": "3.0.0",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "commands",
    "offscreen",
    "scripting",
    "permissions"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Smart Tab Tidy (OpenAI AI)",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "commands": {
    "ai-group-similar-tabs": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "AI Group Similar Tabs"
    },
    "group-by-domain": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "Group tabs by domain"
    },
    "park-tabs": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Park tabs"
    },
    "close-duplicates": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Close duplicate tabs"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
